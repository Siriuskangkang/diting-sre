# ============================================================
# OpsCopilot 环境变量模板
# 使用方法: cp .env.example .env  然后填入你自己的 key
# ============================================================

# ---------- LLM 配置 ----------
# 统一走 OpenAI 兼容接口，切换厂商只需改 base_url + model
# 官方 OpenAI:   https://api.openai.com/v1       model=gpt-4o-mini
# DeepSeek:      https://api.deepseek.com/v1     model=deepseek-chat
# 智谱 GLM:      https://open.bigmodel.cn/api/paas/v4  model=glm-4-flash
# 通义 Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-plus
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ---------- Embedding 配置 ----------
# local: 用 sentence-transformers 本地模型，免 key、免费用（默认推荐）
# openai: 用 OpenAI 兼容 embedding 接口
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_LOCAL=BAAI/bge-small-zh-v1.5
# 仅当 EMBEDDING_PROVIDER=openai 时使用:
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ---------- Rerank (L2) ----------
# 本地 cross-encoder，CPU 可跑；中文场景可换 BAAI/bge-reranker-base
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---------- 向量库 ----------
CHROMA_PERSIST_DIR=./.chroma

# ---------- GitHub MCP Server (L3，可选) ----------
# 自研 MCP Server 调 GitHub API 用；不填则 MCP Server 走 mock 数据
GITHUB_TOKEN=ghp_xxx

# ---------- 基础设施接入（工具适配器，可选）----------
# 配了就查真实数据，不配则自动 mock 兜底（MVP 无基础设施也能跑通闭环）
# PROMETHEUS_URL=http://prometheus:9090
# LOKI_URL=http://loki:3100
# K8S_IN_CLUSTER=false

# ---------- IM 播报（可选）----------
# 配了把排障结果推 IM，都不配则降级写日志 + Web 控制台查看
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx
